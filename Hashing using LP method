#include <stdio.h>

#define SIZE 10

int main()
{
    int hashTable[SIZE], key, i, n, index;

    for(i = 0; i < SIZE; i++)
        hashTable[i] = -1;

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    printf("Enter the elements:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &key);

        index = key % SIZE;

        while(hashTable[index] != -1)
            index = (index + 1) % SIZE;

        hashTable[index] = key;
    }

    printf("\nHash Table:\n");
    for(i = 0; i < SIZE; i++)
    {
        if(hashTable[i] != -1)
            printf("%d --> %d\n", i, hashTable[i]);
        else
            printf("%d --> Empty\n", i);
    }

    return 0;
}
